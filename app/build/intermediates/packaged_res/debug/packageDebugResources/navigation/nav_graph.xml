<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mapFragment">

    <fragment
        android:id="@+id/mapFragment"
        android:name="ru.netology.travelmarkers.ui.MapFragment"
        android:label="Map">
        <action
            android:id="@+id/action_mapFragment_to_markersListFragment"
            app:destination="@id/markersListFragment" />
    </fragment>

    <fragment
        android:id="@+id/markersListFragment"
        android:name="ru.netology.travelmarkers.ui.MarkersListFragment"
        android:label="@string/markers_list">
        <action
            android:id="@+id/action_markersListFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
    </fragment>

</navigation>
